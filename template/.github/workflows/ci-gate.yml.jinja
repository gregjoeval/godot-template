name: CI Gate

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

concurrency:
  group: ci-${{ "{{" }} github.ref {{ "}}" }}
  cancel-in-progress: true

jobs:
  changes:
    runs-on: ubuntu-latest
    timeout-minutes: 1
    outputs:
      csharp: ${{ "{{" }} steps.detect.outputs.csharp {{ "}}" }}
      scenes: ${{ "{{" }} steps.detect.outputs.scenes {{ "}}" }}
      shaders: ${{ "{{" }} steps.detect.outputs.shaders {{ "}}" }}
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - id: detect
        run: |
          if [ "${{ "{{" }} github.event_name {{ "}}" }}" = "pull_request" ]; then
            BASE="${{ "{{" }} github.event.pull_request.base.sha {{ "}}" }}"
          else
            BASE="${{ "{{" }} github.event.before {{ "}}" }}"
          fi
          FILES=$(git diff --name-only "$BASE" HEAD)
          echo "csharp=false" >> "$GITHUB_OUTPUT"
          echo "scenes=false" >> "$GITHUB_OUTPUT"
          echo "shaders=false" >> "$GITHUB_OUTPUT"
          if echo "$FILES" | grep -qE '\.(cs|csproj|sln)$|\.editorconfig$|^\.github/workflows/ci-gate\.yml$'; then
            echo "csharp=true" >> "$GITHUB_OUTPUT"
          fi
          if echo "$FILES" | grep -qE '\.(tscn|tres)$|^project\.godot$|^scripts/tools/normalize_scenes\.sh$|^\.github/workflows/ci-gate\.yml$'; then
            echo "scenes=true" >> "$GITHUB_OUTPUT"
          fi
          if echo "$FILES" | grep -qE '\.gdshader$|^scripts/tools/check_shaders\.sh$'; then
            echo "shaders=true" >> "$GITHUB_OUTPUT"
          fi

  dotnet-build:
    needs: changes
    if: needs.changes.outputs.csharp == 'true'
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - uses: actions/checkout@v4

      - name: Setup .NET
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: 8.0.x

      - name: Setup Godot .NET
        uses: chickensoft-games/setup-godot@v2
        with:
          version: {{ godot_version }}.0
          use-dotnet: true

      - name: Restore
        run: dotnet restore {{ project_pascal }}.sln

      - name: Build
        run: dotnet build {{ project_pascal }}.sln --no-restore -warnaserror

      - name: Restore local tools
        run: dotnet tool restore

      - name: Format check
        run: dotnet csharpier check .

      - name: Test
        run: dotnet test {{ project_pascal }}.sln --no-build

  shader-lint:
    needs: changes
    if: needs.changes.outputs.shaders == 'true'
    runs-on: ubuntu-latest
    timeout-minutes: 1
    steps:
      - uses: actions/checkout@v4
      - name: Check shader processor returns
        run: ./scripts/tools/check_shaders.sh shaders/*.gdshader

  normalize-check:
    needs: changes
    if: needs.changes.outputs.scenes == 'true'
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v4

      - name: Setup .NET
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: 8.0.x

      - name: Setup Godot
        uses: chickensoft-games/setup-godot@v2
        with:
          version: {{ godot_version }}.0
          use-dotnet: true

      - name: Normalize scene/resource files
        run: ./scripts/tools/normalize_scenes.sh godot

      - name: Check for unnormalized files
        run: |
          if ! git diff --exit-code -- '*.tscn' '*.tres' 'project.godot'; then
            echo ""
            echo "ERROR: Scene/resource files are not normalized."
            echo "Run './scripts/tools/normalize_scenes.sh' locally and commit the changes."
            exit 1
          fi

  uid-check:
    runs-on: ubuntu-latest
    timeout-minutes: 1
    steps:
      - uses: actions/checkout@v4

      - name: Check UID sidecar files
        run: ./scripts/tools/check_uids.sh

  gate:
    needs: [dotnet-build, shader-lint, normalize-check, uid-check]
    if: always()
    runs-on: ubuntu-latest
    timeout-minutes: 1
    steps:
      - name: Check results
        run: |
          results=("${{ "{{" }} needs.dotnet-build.result {{ "}}" }}" "${{ "{{" }} needs.shader-lint.result {{ "}}" }}" "${{ "{{" }} needs.normalize-check.result {{ "}}" }}" "${{ "{{" }} needs.uid-check.result {{ "}}" }}")
          for r in "${results[@]}"; do
            if [[ "$r" != "success" && "$r" != "skipped" ]]; then
              echo "FAILED: got '$r'"
              exit 1
            fi
          done
          echo "All checks passed."
