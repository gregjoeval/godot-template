repos:
  - repo: local
    hooks:
      - id: godot-normalize
        name: Normalize Godot scene/resource files
        entry: ./scripts/tools/normalize_scenes.sh
        language: system
        files: '\.(tscn|tres)$|^project\.godot$'
        pass_filenames: false

      - id: shader-no-return
        name: No return in shader processor functions
        entry: ./scripts/tools/check_shaders.sh
        language: system
        files: '\.gdshader$'

      - id: dotnet-build
        name: C# compile and type check
        entry: dotnet build {{ project_pascal }}.sln --no-incremental -warnaserror
        language: system
        files: '\.cs$|\.csproj$'
        pass_filenames: false

      - id: csharpier-check
        name: CSharpier formatting check
        entry: dotnet csharpier check .
        language: system
        files: '\.cs$'
        pass_filenames: false

      - id: dotnet-test
        name: Run gdUnit4Net tests
        entry: dotnet test {{ project_pascal }}.sln --no-build
        language: system
        files: '\.cs$'
        pass_filenames: false

  - repo: https://github.com/commitizen-tools/commitizen
    rev: v4.4.1
    hooks:
      - id: commitizen
        stages: [commit-msg]
