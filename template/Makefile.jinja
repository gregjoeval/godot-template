SOLUTION := {{ project_pascal }}.sln

.PHONY: test build format bump setup

## Run all gdUnit4Net tests.
test:
	dotnet test $(SOLUTION)

## Build with warnings as errors.
build:
	dotnet build $(SOLUTION) -warnaserror

## Check formatting with CSharpier.
format:
	dotnet csharpier check .

## Bump version using conventional commits and generate changelog.
bump:
	cz bump --changelog

## Configure GitHub repo settings and branch protection (requires gh CLI + admin).
setup-repo:
	./scripts/tools/setup-repo.sh
{% if reviewer_github_app_name %}

## Set up GitHub App credentials for reviewer identity.
setup-gh-app:
	./scripts/tools/setup-gh-app.sh
{% endif %}

## Set up development environment (requires .NET runtime and Python 3).
setup:
	git config core.hooksPath tools/hooks
	uv tool install pre-commit
	uv tool install commitizen
	pre-commit install
	dotnet tool restore
	dotnet tool install --global Chickensoft.GodotEnv
	godotenv godot install
	godotenv godot use
