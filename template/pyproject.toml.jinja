[project]
name = "{{ project_slug }}"
version = "0.1.0"
requires-python = ">=3.11"

[tool.commitizen]
name = "cz_conventional_commits"
version = "0.1.0"
version_files = [
    "project.godot:config/version"
]
tag_format = "v$version"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
